# Rust / Cargo
target
**/target

# Tauri artifacts
src-tauri/target
src-tauri/gen
src-tauri/WixTools

# Local model files (download via scripts/fetch-model.sh)
src-tauri/resources/models/*.bin
src-tauri/resources/models/*.mlmodelc/
src-tauri/resources/models/*.mlpackage/
/models/

# Tauri sidecars — the Apple Intelligence sidecar binary is checked
# in at the release tag because GitHub Actions macOS runners don't ship
# the macOS 26 SDK yet (FoundationModels is macOS-26-only). Maintainer
# rebuilds via `scripts/build-apple-polish.sh` on macOS 26 before
# tagging. Local dev rebuilds will show as modified — only commit them
# at release time. (intentionally not gitignored)

# Env
.env
.env.local

# Runtime data
*.sqlite
*.sqlite-journal
*.db
*.db-journal

# Icon outputs from `scripts/regen-icons.sh` that we don't bundle.
# tauri.conf.json's `bundle.icon` only lists 32x32 / 128x128 /
# 128x128@2x — ignore the rest so a re-run doesn't clutter git status.
/src-tauri/icons/android/
/src-tauri/icons/ios/
/src-tauri/icons/Square*Logo.png
/src-tauri/icons/StoreLogo.png
/src-tauri/icons/64x64.png
/src-tauri/icons/icon.icns
/src-tauri/icons/icon.ico
